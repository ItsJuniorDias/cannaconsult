{
  "expo": {
    "name": "cannaconsult",
    "slug": "cannaconsult",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cannaconsult",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.cannaconsult",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Precisamos do FaceID para autorizar a assinatura digital de documentos médicos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.cannaconsult"
    },
    "splash": null,
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o aplicativo acesse sua câmera para as videoconsultas."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Permitir que o aplicativo acesse seu microfone para as videoconsultas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
